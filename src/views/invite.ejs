<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= inviterName %> wants to be your workout buddy!</title>

    <!-- Open Graph / iMessage rich preview -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= inviteUrl %>">
    <meta property="og:title" content="<%= inviterName %> wants to be your workout buddy! 🏋️">
    <meta property="og:description" content="Tap to add them as a friend and track your workouts together.">
    <% if (inviterPicture) { %>
    <meta property="og:image" content="<%= inviterPicture %>">
    <% } %>

    <!-- Twitter/iMessage fallbacks -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= inviterName %> wants to be your workout buddy! 🏋️">
    <meta name="twitter:description" content="Tap to add them as a friend and track your workouts together.">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0f0f0f;
            color: #fff;
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.5rem;
        }
        .card {
            text-align: center;
            max-width: 360px;
            width: 100%;
        }
        .avatar {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            margin: 0 auto 1.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #1a1a1a;
            font-size: 2.5rem;
            overflow: hidden;
        }
        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .emoji-icon {
            font-size: 3rem;
            display: block;
            margin: 0 auto 1.25rem;
        }
        h1 {
            font-size: 1.35rem;
            font-weight: 800;
            line-height: 1.3;
            margin-bottom: 0.6rem;
        }
        .sub {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 2rem;
            line-height: 1.5;
        }
        .btn-accept {
            display: block;
            width: 100%;
            background: #4f9eff;
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 0.9rem 1.5rem;
            font-size: 1rem;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
        }
        .btn-accept:active { opacity: 0.85; }
    </style>
</head>
<body>
    <div class="card">
        <% if (inviterPicture) { %>
        <div class="avatar"><img src="<%= inviterPicture %>" alt="<%= inviterName %>"></div>
        <% } else { %>
        <span class="emoji-icon">🏋️</span>
        <% } %>

        <h1><%= inviterName %> wants to be your workout buddy!</h1>
        <p class="sub">Add them as a friend and share your training progress together.</p>

        <a href="/invite/<%= token %>/accept" class="btn-accept">Add as Friend</a>
    </div>
</body>
</html>
