<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0f0f0f;
            color: #fff;
            min-height: 100dvh;
            padding: 1.5rem 1rem 3rem;
            max-width: 700px;
            margin: 0 auto;
        }
        h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.25rem; }
        .subtitle { font-size: 0.85rem; color: #555; margin-bottom: 1.25rem; }
        .filters { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
        .filters input, .filters select {
            background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px;
            color: #fff; font-size: 0.9rem; padding: 0.55rem 0.75rem; outline: none;
        }
        .filters input { flex: 1; }
        .user-block { margin-bottom: 2rem; }
        .user-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
        .user-name { font-size: 1rem; font-weight: 700; }
        .user-id { font-size: 0.72rem; color: #444; margin-top: 0.1rem; }
        .section-label {
            font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.1em; color: #555; margin: 0.9rem 0 0.4rem;
        }
        .log-row {
            display: flex; align-items: center; justify-content: space-between;
            gap: 0.5rem; padding: 0.5rem 0.75rem; background: #1a1a1a;
            border-radius: 8px; margin-bottom: 0.3rem;
        }
        .log-date { font-size: 0.72rem; color: #555; }
        .edit-num {
            width: 80px; background: #111; border: 1px solid #2a2a2a; border-radius: 6px;
            color: #fff; font-size: 0.85rem; padding: 0.28rem 0.5rem; outline: none; text-align: right;
        }
        .edit-text {
            flex: 1; background: transparent; border: none; border-bottom: 1px solid #2a2a2a;
            color: #fff; font-size: 0.85rem; padding: 0.1rem 0.25rem; outline: none; min-width: 0;
        }
        .edit-select {
            background: #111; border: 1px solid #2a2a2a; border-radius: 6px;
            color: #fff; font-size: 0.78rem; padding: 0.28rem 0.4rem; outline: none;
        }
        .unit { font-size: 0.72rem; color: #555; flex-shrink: 0; }
        .btn-del {
            background: none; border: 1px solid #3a1a1a; color: #e05252;
            border-radius: 6px; padding: 0.25rem 0.55rem; font-size: 0.78rem; cursor: pointer; flex-shrink: 0;
        }
        .btn-del-all {
            background: none; border: 1px solid #3a1a1a; color: #e05252;
            border-radius: 6px; padding: 0.3rem 0.75rem; font-size: 0.78rem; font-weight: 600; cursor: pointer;
        }
        .back { display: inline-flex; align-items: center; gap: 0.3rem; color: #4f9eff;
                font-size: 0.9rem; font-weight: 600; text-decoration: none; margin-bottom: 1.5rem; }
        .divider { border: none; border-top: 1px solid #1e1e1e; margin: 1.5rem 0; }
        .empty { color: #444; font-size: 0.85rem; padding: 0.5rem 0; }
        .tm-history-toggle {
            background: none; border: none; color: #444; font-size: 0.75rem;
            cursor: pointer; padding: 0.2rem 0; margin-top: 0.5rem;
        }
        .tm-history { display: none; }
    </style>
</head>
<body>

    <a href="/" class="back">← Back</a>
    <h1>Admin</h1>
    <div class="subtitle">
        <span id="visibleCount"><%= users.length %></span> of <%= users.length %> users &nbsp;·&nbsp; <%= totalLogs %> TM log entries
    </div>
    <div style="margin-bottom:1.5rem;">
        <button onclick="clearGuideCache()"
                style="background:none;border:1px solid #2a2a2a;border-radius:8px;color:#555;
                       font-size:0.8rem;padding:0.4rem 0.8rem;cursor:pointer;">
            Clear exercise guide cache
        </button>
        <span id="guide-clear-status" style="font-size:0.78rem;color:#4ade80;margin-left:0.5rem;display:none;">Cleared!</span>
    </div>

    <div class="filters">
        <input type="text" id="userSearch" placeholder="Search users…" oninput="filterAdmin()"/>
        <select id="liftFilter" onchange="filterAdmin()">
            <option value="">All lifts</option>
            <% [...new Set(users.flatMap(u => u.tmConfigs.map(c => c.lift.name)))].sort().forEach(lift => { %>
                <option value="<%= lift %>"><%= lift %></option>
            <% }) %>
        </select>
    </div>

    <% if (users.length === 0) { %>
        <div class="empty">No users found.</div>
    <% } %>

    <% users.forEach(u => { %>
    <div class="user-block">
        <div class="user-header">
            <div>
                <div class="user-name"><%= u.displayName %></div>
                <div class="user-id"><%= u.userId %></div>
            </div>
            <form action="/admin/tm-log/delete-user/<%= encodeURIComponent(u.userId) %>" method="post"
                  onsubmit="return confirm('Clear all TM logs for <%= u.displayName %>?')">
                <button type="submit" class="btn-del-all">Clear TM logs</button>
            </form>
        </div>

        <!-- Training Maxes -->
        <div class="section-label">Training Maxes</div>
        <% if (u.tmConfigs.length === 0) { %><div class="empty">None</div><% } %>
        <% u.tmConfigs.forEach(config => { %>
        <div class="log-row" id="tm-config-<%= config.id %>">
            <span style="font-size:0.88rem;font-weight:600;flex:1;"><%= config.lift.name %></span>
            <div style="display:flex;align-items:center;gap:0.4rem;">
                <input type="number" value="<%= config.trainingMax %>" step="2.5" min="45" class="edit-num"
                       onchange="adminSave('/admin/tm-config/update/<%= config.id %>', {trainingMax: this.value}, this)"/>
                <span class="unit">lbs</span>
                <select class="edit-select"
                        onchange="adminSave('/admin/tm-config/update/<%= config.id %>', {currentWeek: this.value}, this)">
                    <option value="1" <%= config.currentWeek === 1 ? 'selected' : '' %>>Wk 1</option>
                    <option value="2" <%= config.currentWeek === 2 ? 'selected' : '' %>>Wk 2</option>
                    <option value="3" <%= config.currentWeek === 3 ? 'selected' : '' %>>Wk 3</option>
                    <option value="4" <%= config.currentWeek === 4 ? 'selected' : '' %>>Wk 4</option>
                </select>
            </div>
        </div>
        <% }) %>

        <!-- Weight Log -->
        <div class="section-label">Weight Log</div>
        <% if (u.weightLogs.length === 0) { %><div class="empty">None</div><% } %>
        <% u.weightLogs.forEach(w => { %>
        <div class="log-row" id="weight-<%= w.id %>">
            <span class="log-date"><%= w.loggedOn %></span>
            <div style="display:flex;align-items:center;gap:0.4rem;">
                <input type="number" value="<%= w.weightLbs %>" step="0.1" class="edit-num"
                       onchange="adminSave('/admin/weight/update/<%= w.id %>', {weightLbs: this.value}, this)"/>
                <span class="unit">lbs</span>
                <button class="btn-del" onclick="adminDelete('/admin/weight/delete/<%= w.id %>', 'weight-<%= w.id %>')">×</button>
            </div>
        </div>
        <% }) %>

        <!-- Calorie Log -->
        <div class="section-label">Calorie Log</div>
        <% if (u.calEntries.length === 0) { %><div class="empty">None</div><% } %>
        <% u.calEntries.forEach(c => { %>
        <div class="log-row" id="cal-<%= c.id %>">
            <div style="flex:1;min-width:0;margin-right:0.5rem;">
                <input type="text" value="<%= c.description %>" maxlength="200" class="edit-text"
                       onchange="adminSave('/admin/cals/update/<%= c.id %>', {description: this.value}, this)"/>
                <div class="log-date"><%= c.loggedOn %></div>
            </div>
            <div style="display:flex;align-items:center;gap:0.4rem;flex-shrink:0;">
                <input type="number" value="<%= c.calories %>" min="1" class="edit-num"
                       onchange="adminSave('/admin/cals/update/<%= c.id %>', {calories: this.value}, this)"/>
                <span class="unit">kcal</span>
                <button class="btn-del" onclick="adminDelete('/admin/cals/delete/<%= c.id %>', 'cal-<%= c.id %>')">×</button>
            </div>
        </div>
        <% }) %>

        <!-- TM History (collapsed) -->
        <% if (u.tmLogs.length > 0) { %>
        <button class="tm-history-toggle" onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'none' ? 'block' : 'none'; this.textContent = this.textContent.includes('▶') ? '▼ Hide TM history' : '▶ Show TM history';">
            ▶ Show TM history
        </button>
        <div class="tm-history">
            <% u.tmLogs.forEach(l => { %>
            <div style="margin-bottom:0.75rem;">
                <div class="section-label" style="margin-top:0.5rem;"><%= l.liftName %></div>
                <% l.entries.forEach(entry => { %>
                <div class="log-row">
                    <div>
                        <div style="font-size:0.85rem;"><%= entry.trainingMax %> lbs</div>
                        <div class="log-date"><%= entry.loggedOn %></div>
                    </div>
                    <form action="/admin/tm-log/delete/<%= entry.id %>" method="post" style="margin:0;">
                        <button type="submit" class="btn-del">×</button>
                    </form>
                </div>
                <% }) %>
            </div>
            <% }) %>
        </div>
        <% } %>

        <hr class="divider">
    </div>
    <% }) %>

    <script>
        document.addEventListener('touchmove', function(e) { if (e.touches.length > 1) e.preventDefault(); }, { passive: false });

        async function adminSave(url, data, el) {
            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                el.style.outline = res.ok ? '2px solid #4ade80' : '2px solid #e05252';
                setTimeout(() => el.style.outline = '', 1500);
            } catch(e) {
                el.style.outline = '2px solid #e05252';
                setTimeout(() => el.style.outline = '', 1500);
            }
        }

        async function adminDelete(url, rowId) {
            if (!confirm('Delete this entry?')) return;
            const res = await fetch(url, { method: 'POST' });
            if (res.ok) document.getElementById(rowId)?.remove();
        }

        async function clearGuideCache() {
            const res = await fetch('/admin/guides/clear', { method: 'POST' });
            if (res.ok) {
                const s = document.getElementById('guide-clear-status');
                s.style.display = 'inline';
                setTimeout(() => s.style.display = 'none', 2000);
            }
        }

        function filterAdmin() {
            const search = document.getElementById('userSearch').value.toLowerCase();
            const lift = document.getElementById('liftFilter').value;
            let visible = 0;
            document.querySelectorAll('.user-block').forEach(block => {
                const name = block.querySelector('.user-name').textContent.toLowerCase();
                const id = block.querySelector('.user-id').textContent.toLowerCase();
                if (search && !name.includes(search) && !id.includes(search)) {
                    block.style.display = 'none'; return;
                }
                if (lift) {
                    const hasLift = [...block.querySelectorAll('#tm-config-* span')].some(s => s.textContent === lift)
                        || [...block.querySelectorAll('.log-row span')].some(s => s.textContent === lift);
                    if (!hasLift) { block.style.display = 'none'; return; }
                }
                block.style.display = ''; visible++;
            });
            document.getElementById('visibleCount').textContent = visible;
        }
    </script>
</body>
</html>
