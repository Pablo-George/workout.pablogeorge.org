<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0f0f0f;
            color: #fff;
            min-height: 100dvh;
            padding: 1.5rem 1rem 3rem;
            max-width: 700px;
            margin: 0 auto;
        }
        h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.25rem; }
        .subtitle { font-size: 0.85rem; color: #555; margin-bottom: 2rem; }
        .user-block { margin-bottom: 2rem; }
        .user-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.75rem;
        }
        .user-name { font-size: 1rem; font-weight: 700; }
        .user-id { font-size: 0.72rem; color: #444; margin-top: 0.1rem; }
        .lift-block { margin-bottom: 1rem; }
        .lift-name {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #555;
            margin-bottom: 0.4rem;
        }
        .log-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.6rem 0.9rem;
            background: #1a1a1a;
            border-radius: 8px;
            margin-bottom: 0.3rem;
        }
        .log-info { font-size: 0.88rem; }
        .log-date { font-size: 0.75rem; color: #555; margin-top: 0.1rem; }
        .btn-del {
            background: none;
            border: 1px solid #3a1a1a;
            color: #e05252;
            border-radius: 6px;
            padding: 0.3rem 0.65rem;
            font-size: 0.75rem;
            cursor: pointer;
            white-space: nowrap;
        }
        .btn-del-all {
            background: none;
            border: 1px solid #3a1a1a;
            color: #e05252;
            border-radius: 6px;
            padding: 0.3rem 0.75rem;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: pointer;
        }
        .back { display: inline-flex; align-items: center; gap: 0.3rem; color: #4f9eff;
                font-size: 0.9rem; font-weight: 600; text-decoration: none; margin-bottom: 1.5rem; }
        .divider { border: none; border-top: 1px solid #1e1e1e; margin: 1.5rem 0; }
        .empty { color: #444; font-size: 0.88rem; }
    </style>
</head>
<body>

    <a href="/" class="back">← Back</a>

    <h1>Admin</h1>
    <div class="subtitle"><span id="visibleCount"><%= users.length %></span> of <%= users.length %> <%= users.length === 1 ? 'user' : 'users' %> &nbsp;·&nbsp; <%= totalLogs %> TM <%= totalLogs === 1 ? 'entry' : 'entries' %></div>

    <div style="display:flex;gap:0.5rem;margin-bottom:1.5rem;">
        <input type="text" id="userSearch" placeholder="Search users…" oninput="filterAdmin()"
               style="flex:1;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:8px;
                      color:#fff;font-size:0.9rem;padding:0.55rem 0.75rem;outline:none;"/>
        <select id="liftFilter" onchange="filterAdmin()"
                style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:8px;
                       color:#fff;font-size:0.9rem;padding:0.55rem 0.75rem;outline:none;">
            <option value="">All lifts</option>
            <% [...new Set(users.flatMap(u => u.lifts.map(l => l.liftName)))].sort().forEach(lift => { %>
                <option value="<%= lift %>"><%= lift %></option>
            <% }) %>
        </select>
    </div>

    <% if (users.length === 0) { %>
        <div class="empty">No TM log entries.</div>
    <% } %>

    <% users.forEach(u => { %>
    <div class="user-block">
        <div class="user-header">
            <div>
                <div class="user-name"><%= u.displayName %></div>
                <div class="user-id"><%= u.userId %></div>
            </div>
            <form action="/admin/tm-log/delete-user/<%= u.userId %>" method="post"
                  onsubmit="return confirm('Delete all TM logs for <%= u.displayName %>?')">
                <button type="submit" class="btn-del-all">Clear all</button>
            </form>
        </div>

        <% u.lifts.forEach(l => { %>
        <div class="lift-block">
            <div class="lift-name"><%= l.liftName %></div>
            <% l.entries.forEach(entry => { %>
            <div class="log-row">
                <div>
                    <div class="log-info"><%= entry.trainingMax %> lbs</div>
                    <div class="log-date"><%= entry.loggedOn %></div>
                </div>
                <form action="/admin/tm-log/delete/<%= entry.id %>" method="post">
                    <button type="submit" class="btn-del">Delete</button>
                </form>
            </div>
            <% }) %>
        </div>
        <% }) %>
        <hr class="divider">
    </div>
    <% }) %>
    <script>
        document.addEventListener('touchmove', function(e) { if (e.touches.length > 1) e.preventDefault(); }, { passive: false });

        function filterAdmin() {
            const search = document.getElementById('userSearch').value.toLowerCase();
            const lift = document.getElementById('liftFilter').value;
            let visible = 0;

            document.querySelectorAll('.user-block').forEach(block => {
                const name = block.querySelector('.user-name').textContent.toLowerCase();
                const id = block.querySelector('.user-id').textContent.toLowerCase();
                if (search && !name.includes(search) && !id.includes(search)) {
                    block.style.display = 'none';
                    return;
                }

                let hasVisible = true;
                if (lift) {
                    hasVisible = false;
                    block.querySelectorAll('.lift-block').forEach(lb => {
                        const match = lb.querySelector('.lift-name').textContent === lift;
                        lb.style.display = match ? '' : 'none';
                        if (match) hasVisible = true;
                    });
                } else {
                    block.querySelectorAll('.lift-block').forEach(lb => lb.style.display = '');
                }

                block.style.display = hasVisible ? '' : 'none';
                if (hasVisible) visible++;
            });

            document.getElementById('visibleCount').textContent = visible;
        }
    </script>

</body>
</html>
